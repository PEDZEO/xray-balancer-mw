# ─── Xray Balancer Middleware ─── #
# Скопируй в .env и заполни свои значения:
#   cp .env.example .env && nano .env

# URL панели Remnawave (обязательно)
REMNAWAVE_URL=https://panel.example.com

# Внутренний Docker-адрес subscription page (обязательно)
SUB_PAGE_URL=http://subscription-page:3010

# Публичный домен подписки (обязательно)
SUB_DOMAIN=sub.example.com

# API токен панели (для auto_groups и node_stats)
API_TOKEN=

# Cookie для панели за nginx (egam.es). Оставь пустым если не нужен
PANEL_AUTH_COOKIE=
