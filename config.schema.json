{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "xray-balancer-mw config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "sub_path": { "type": "string", "pattern": "^/" },
    "strategy": { "type": "string", "enum": ["leastLoad", "random", "roundRobin"] },
    "profile_mode": { "type": "string", "enum": ["balanced", "stable", "aggressive", "debug"] },
    "probe_interval": { "type": "string" },
    "probe_url": { "type": "string", "pattern": "^https?://" },
    "fastest_probe_url": { "type": "string", "pattern": "^https?://" },
    "fastest_group": { "type": "boolean" },
    "fastest_group_name": { "type": "string", "minLength": 1 },
    "fastest_exclude_groups": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "fastest_fallback": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "node_stats_exclude": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expand_groups_to_nodes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "hidden_groups": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "hidden_nodes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "auto_groups": { "type": "boolean" },
    "auto_groups_interval_sec": { "type": "integer", "minimum": 1 },
    "node_stats": { "type": "boolean" },
    "node_stats_interval_sec": { "type": "integer", "minimum": 1 },
    "max_users_per_gb": { "type": "integer", "minimum": 1 },
    "max_users_per_cpu": { "type": "integer", "minimum": 1 },
    "cache_ttl_sec": { "type": "integer", "minimum": 1 },
    "cache_stale_if_error_sec": { "type": "integer", "minimum": 1 },
    "cache_max_entries": { "type": "integer", "minimum": 1 },
    "rate_limit_per_minute": { "type": "integer", "minimum": 1 },
    "rate_limit_burst_10s": { "type": "integer", "minimum": 1 },
    "token_rate_limit_per_minute": { "type": "integer", "minimum": 1 },
    "token_rate_limit_burst_10s": { "type": "integer", "minimum": 1 },
    "token_limiter_max_entries": { "type": "integer", "minimum": 1 },
    "token_limiter_cleanup_batch": { "type": "integer", "minimum": 1 },
    "admin_rate_limit_per_minute": { "type": "integer", "minimum": 1 },
    "admin_rate_limit_burst_10s": { "type": "integer", "minimum": 1 },
    "trust_x_forwarded_for": { "type": "boolean" },
    "auto_quarantine_enabled": { "type": "boolean" },
    "auto_quarantine_failures": { "type": "integer", "minimum": 1 },
    "auto_quarantine_release_successes": { "type": "integer", "minimum": 1 },
    "auto_quarantine_max_nodes": { "type": "integer", "minimum": 1 },
    "auto_drain_enabled": { "type": "boolean" },
    "auto_drain_failures": { "type": "integer", "minimum": 1 },
    "auto_drain_release_successes": { "type": "integer", "minimum": 1 },
    "auto_drain_load_threshold": { "type": "number", "minimum": 0 },
    "auto_drain_score_penalty": { "type": "number", "minimum": 0 },
    "sticky_enabled": { "type": "boolean" },
    "sticky_mode": { "type": "string", "enum": ["pin", "prefer"] },
    "sticky_new_connections_only": { "type": "boolean" },
    "sticky_ttl_sec": { "type": "integer", "minimum": 1 },
    "sticky_max_entries": { "type": "integer", "minimum": 1 },
    "balancer_load_weight": { "type": "number", "minimum": 0 },
    "balancer_latency_weight": { "type": "number", "minimum": 0 },
    "balancer_max_latency_ms": { "type": "integer", "minimum": 1 },
    "balancer_smoothing_alpha": { "type": "number", "minimum": 0 },
    "balancer_hysteresis_delta": { "type": "number", "minimum": 0 },
    "ready_success_window_sec": { "type": "integer", "minimum": 1 },
    "request_timeout_ms": { "type": "integer", "minimum": 1 },
    "max_redirects": { "type": "integer", "minimum": 1 },
    "circuit_breaker_failures": { "type": "integer", "minimum": 1 },
    "circuit_breaker_open_sec": { "type": "integer", "minimum": 1 },
    "admin_token": { "type": "string", "minLength": 8 },
    "warmup_tokens": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" }
    },
    "quarantine_nodes": {
      "type": "array",
      "maxItems": 500,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "auto_quarantine_nodes": {
      "type": "array",
      "maxItems": 500,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "groups": {
      "type": "object",
      "maxProperties": 100,
      "propertyNames": { "type": "string", "minLength": 1, "maxLength": 64 },
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1, "maxLength": 128 },
        "minItems": 1,
        "maxItems": 100
      }
    }
  }
}
