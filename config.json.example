{
    "port": 4100,
    "sub_path": "/api/sub",

    "strategy": "leastLoad",
    "profile_mode": "balanced",
    "probe_interval": "3m",
    "probe_url": "https://www.gstatic.com/generate_204",
    "fastest_probe_url": "https://ya.ru",

    "fastest_group": true,
    "fastest_group_name": "🏁 🇪🇺 Самые быстрые",
    "fastest_exclude_groups": [],
    "fastest_fallback": [],
    "node_stats_exclude": [],
    "hidden_groups": [],
    "hidden_nodes": [],
    "auto_groups": false,
    "auto_groups_interval_sec": 300,

    "node_stats": false,
    "node_stats_interval_sec": 120,
    "max_users_per_gb": 20,
    "max_users_per_cpu": 40,
    "cache_ttl_sec": 300,
    "cache_stale_if_error_sec": 1800,
    "cache_max_entries": 1000,
    "rate_limit_per_minute": 120,
    "rate_limit_burst_10s": 30,
    "token_rate_limit_per_minute": 240,
    "token_rate_limit_burst_10s": 60,
    "admin_rate_limit_per_minute": 60,
    "admin_rate_limit_burst_10s": 20,
    "trust_x_forwarded_for": false,
    "auto_quarantine_enabled": false,
    "auto_quarantine_failures": 3,
    "auto_quarantine_release_successes": 2,
    "auto_quarantine_max_nodes": 100,
    "auto_drain_enabled": false,
    "auto_drain_failures": 2,
    "auto_drain_release_successes": 2,
    "auto_drain_load_threshold": 0.85,
    "auto_drain_score_penalty": 0.6,
    "sticky_enabled": true,
    "sticky_mode": "prefer",
    "sticky_new_connections_only": true,
    "sticky_ttl_sec": 300,
    "sticky_max_entries": 10000,
    "balancer_load_weight": 0.4,
    "balancer_latency_weight": 0.6,
    "balancer_max_latency_ms": 300,
    "balancer_smoothing_alpha": 0.35,
    "balancer_hysteresis_delta": 0.08,
    "ready_success_window_sec": 300,
    "request_timeout_ms": 10000,
    "max_redirects": 3,
    "circuit_breaker_failures": 6,
    "circuit_breaker_open_sec": 30,
    "admin_token": "",
    "warmup_tokens": [],
    "quarantine_nodes": [],

    "groups": {
        "🇫🇮 Finland": ["Finland"],
        "🇩🇪 Germany": ["German"],
        "🇳🇱 Netherlands": ["Netherlands"],
        "🇪🇺 Europe LTE": ["ЕВРОПА", "LTE"]
    }
}
