{
    "port": 4100,
    "sub_path": "/api/sub",

    "strategy": "leastLoad",
    "probe_interval": "3m",
    "probe_url": "https://www.gstatic.com/generate_204",

    "fastest_group": true,
    "auto_groups": false,

    "node_stats": false,
    "node_stats_interval_sec": 120,
    "max_users_per_gb": 20,

    "groups": {
        "🇫🇮 Finland": ["Finland"],
        "🇩🇪 Germany": ["German"],
        "🇳🇱 Netherlands": ["Netherlands"],
        "🇪🇺 Europe LTE": ["ЕВРОПА", "LTE"]
    }
}
